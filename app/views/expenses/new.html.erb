<h1>Add Expenses</h1>
<%= form_with(model: @expense, local: true) do |form| %>
    <div>
        <%= form.label :amount %>
        <%= form.number_field :amount, step: 0.01, required: true %>
    </div>

    <div>
        <%= form.label :description %>
        <%= form.text_field :description, required: true %>
    </div>

    <div>
        <%= form.label :category %>
        <%= form.text_field :cateogry %>
    </div>

    <div>
        <%= form.label :date %>
        <%= form.date_field :date, required: true %>
    </div>

    <div>
        <%= form.submit "Add Expense" %>
    </div>
<% end %>

<%= link_to "Back to Expenses", expenses_path %>